<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 預設 log 目錄；可被 logging.file.path 環境變數覆寫 -->
    <property name="LOG_DIR" value="${LOG_DIR:-./logs}"/>
    <property name="APP_NAME" value="pobar"/>

    <!-- Console（彩色，給開發 / docker logs 看） -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 一般 log（時間 + 大小雙條件輪轉，保留 30 天） -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ERROR 專屬 log -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ───────── 保底 root：profile 沒匹配時至少有 console，避免「啞 backend」 ───────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- ───────── local：本機開發，console + file，DEBUG ───────── -->
    <springProfile name="local,default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.pobar" level="DEBUG"/>
        <logger name="com.pobar.mapper" level="DEBUG"/>
    </springProfile>

    <!-- ───────── sit：Docker 測試，console（docker logs）+ file ───────── -->
    <springProfile name="sit">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.pobar" level="INFO"/>
        <logger name="com.pobar.mapper" level="WARN"/>
    </springProfile>

    <!-- ───────── prod：正式環境，只寫 file，WARN ───────── -->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
            <!-- 仍寫 console，方便 docker logs / CloudWatch agent 收集 -->
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.pobar" level="INFO"/>
        <logger name="com.pobar.mapper" level="WARN"/>
    </springProfile>

</configuration>
