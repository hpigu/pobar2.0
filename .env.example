# ═══════════════════════════════════════════════════════════
# .env 範例檔 — 複製為 .env 後填入實際值
# .env 已被 .gitignore，絕對不可入版控
#
# 詳細說明請見 docs/env-setup.md
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────
# Profile（sit | prod）
# ─────────────────────────────────────────
SPRING_PROFILES_ACTIVE=sit

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_to_strong_password
DB_USER=pobar
DB_PASSWORD=change_me_to_strong_password

# ─────────────────────────────────────────
# JWT（必填，用 openssl rand -base64 48 產生）
# ─────────────────────────────────────────
JWT_SECRET=replace_with_at_least_64_chars_random_string

# ─────────────────────────────────────────
# 初始管理員（首次啟動後立即改密碼，並把這行清空再重啟）
# ─────────────────────────────────────────
INIT_ADMIN_ACCOUNT=admin
INIT_ADMIN_PASSWORD=change_me_on_first_login

# ─────────────────────────────────────────
# CORS（多個 origin 用逗號分隔）
# 走 nginx 反向代理時不需設定（同 origin 不會觸發 CORS）
# 若前後端分 domain 部署才需要填，例如：
#   CORS_ALLOWED_ORIGINS=https://www.pobar.com,https://admin.pobar.com
# ─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=

# ─────────────────────────────────────────
# ECPay（綠界，未申請前留空，發票功能會自動 disable）
# ─────────────────────────────────────────
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_INVOICE_API_URL=https://einvoice-stage.ecpay.com.tw/B2CInvoice/Issue

# ─────────────────────────────────────────
# 儲存（未來上 AWS S3 時改為 s3 並填四個 S3_* 變數）
# ─────────────────────────────────────────
STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=ap-northeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
