# ── 資料庫 ──────────────────────────────────────────────
# MySQL root 密碼（首次建立後請勿更改）
MYSQL_ROOT_PASSWORD=換成自訂密碼

# 應用程式連線帳號密碼
DB_USER=pobar
DB_PASSWORD=換成自訂密碼

# ── JWT 密鑰（請換成 64 字元以上的隨機字串）───────────
JWT_SECRET=換成64字元以上的隨機字串_例如用openssl_rand_hex_32產生

# ── 首次啟動建立 admin 帳號 ──────────────────────────
# 設定後啟動系統，管理員帳號「admin」會自動建立
# 建立後請刪除此行或留空（留空不會重複建立）
INIT_ADMIN_PASSWORD=
